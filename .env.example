# =============================================================================
# Counseling Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# The .env file is gitignored. Never commit secrets.
# =============================================================================

# --- PostgreSQL — Meta DB (counseling-postgres-meta, port 5432) ---
META_DB_HOST=localhost
META_DB_PORT=5432
META_DB_NAME=meta_db
META_DB_USER=admin
META_DB_PASSWORD=admin
META_DB_URL=r2dbc:postgresql://localhost:5432/meta_db

# --- PostgreSQL — Tenant DB (counseling-postgres-tenant, port 5433) ---
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5433
TENANT_DB_NAME=tenant_default
TENANT_DB_USER=admin
TENANT_DB_PASSWORD=admin
TENANT_DB_URL=r2dbc:postgresql://localhost:5433/tenant_default

# --- MongoDB — Read-side CQRS (counseling-mongodb, port 27017) ---
MONGODB_URI=mongodb://localhost:27017/counseling_read

# --- Redis — Token Blacklist & Session (counseling-redis, port 6379) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- LiveKit — WebRTC SFU (counseling-livekit, port 7880/7881/7882) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- JWT ---
JWT_SECRET=change-this-to-a-long-random-secret-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# --- Server ---
API_PORT=8080
API_ADMIN_PORT=8081

# --- Storage ---
RECORDING_STORAGE_PATH=./storage/recordings
FILE_STORAGE_PATH=./storage/files
CAPTURE_STORAGE_PATH=./storage/captures
